# OpenVPN Client Configuration
# Generated for use with the IaC-deployed OpenVPN server

client
dev tun
proto udp

# Replace with the public IP or DNS of your OpenVPN server
remote <SERVER_PUBLIC_IP> 1194

resolv-retry infinite
nobind

# Persist key and tun across restarts
persist-key
persist-tun

# Certificate and key files (inline or file paths)
# Option 1: Reference external files
# ca ca.crt
# cert client.crt
# key client.key

# Option 2: Inline certificates (preferred for portable .ovpn files)
# Paste the contents of each file between the tags below:

# <ca>
# -----BEGIN CERTIFICATE-----
# (contents of /etc/openvpn/easy-rsa/pki/ca.crt)
# -----END CERTIFICATE-----
# </ca>

# <cert>
# -----BEGIN CERTIFICATE-----
# (contents of /etc/openvpn/easy-rsa/pki/issued/client.crt)
# -----END CERTIFICATE-----
# </cert>

# <key>
# -----BEGIN PRIVATE KEY-----
# (contents of /etc/openvpn/easy-rsa/pki/private/client.key)
# -----END PRIVATE KEY-----
# </key>

# TLS-auth key (must match server; key-direction 1 for client)
key-direction 1
# <tls-auth>
# -----BEGIN OpenVPN Static key V1-----
# (contents of /etc/openvpn/ta.key)
# -----END OpenVPN Static key V1-----
# </tls-auth>

# Verify server certificate type
remote-cert-tls server

# Logging verbosity (0 = silent, 4 = normal, 9 = debug)
verb 3
